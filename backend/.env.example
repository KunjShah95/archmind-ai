DATABASE_URL=sqlite:///./archmind.db
UPLOADS_DIR=./uploads
# Local dev origins. In production (Render), set this to your Vercel domain(s):
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app-git-main-yourname.vercel.app
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
DEV_MODE=true
# WARNING: Change this secret for any non-local deployment. The default value is insecure.
# Override via DEV_JWT_SECRET environment variable in your production environment.
DEV_JWT_SECRET=archmind-dev-secret-change-in-production

# Optional: set REDIS_URL=redis://localhost:6379 to enable LLM response caching
# REDIS_URL=redis://localhost:6379

# Production: point to Supabase Postgres
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret
