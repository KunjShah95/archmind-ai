# Frontend (optional — local dev works without Supabase via demo login)
VITE_API_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ───────────────────────────────────────────────────────────────
# Backend LLM providers (all have free tiers). Configure ANY one —
# the agent engine uses the first that responds and falls back to
# the next, then to the built-in heuristic engine if none are set.
# Priority is left-to-right in LLM_PROVIDER_ORDER (default below).
# ───────────────────────────────────────────────────────────────
# LLM_PROVIDER_ORDER=groq,nvidia,openrouter,gemini,ollama,huggingface
#
# Image/diagram uploads use a vision model (per provider, free defaults built in).
# Override any with <PROVIDER>_VISION_MODEL, e.g. GEMINI_VISION_MODEL, OLLAMA_VISION_MODEL.
# Vision requests follow the same fallback chain: if one provider is rate-limited,
# the next configured provider takes over automatically.

# Groq — https://console.groq.com (fast, free tier)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct  # for image/diagram uploads

# NVIDIA NIM — https://build.nvidia.com (free credits, OpenAI-compatible)
NVIDIA_API_KEY=
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# OpenRouter — https://openrouter.ai (single key, many free models)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Google Gemini — https://aistudio.google.com/apikey (free tier)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Ollama — local, no key (run `ollama serve`)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# HuggingFace Inference API — https://huggingface.co/settings/tokens
HF_API_KEY=
# HF_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# Generic OpenAI-compatible endpoint (set both to enable)
OPENAI_API_KEY=
OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini
